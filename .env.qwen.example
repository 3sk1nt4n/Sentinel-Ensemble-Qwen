# ── Qwen Cloud (Alibaba Cloud / DashScope) provider config ────────────────
# Global AI Hackathon with Qwen Cloud -- Track 4 (Autopilot Agent).
#
# Copy to .env (or `source` it) and fill in DASHSCOPE_API_KEY. Flipping the
# whole 16-step pipeline onto Qwen needs NO code change -- model selection is
# already env-driven (src/sift_sentinel/model_roles.py). The provider seam is
# src/sift_sentinel/llm_provider.py.

# 1) Select the Qwen provider (anything else -> Anthropic, the default).
SIFT_LLM_PROVIDER=qwen

# 2) Your Qwen Cloud key (request the $40 hackathon voucher; key from the
#    DashScope console). QWEN_API_KEY is also accepted.
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# 3) Endpoint. Default is the INTERNATIONAL (Singapore) OpenAI-compatible URL.
#    For mainland China use:
#    https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions

# 4) Models (verify exact current IDs in your DashScope model list).
#    Strategy: flagship qwen3.7-max where reasoning matters; qwen-plus on the
#    high-call-volume stages so the $40 credit lasts. (Plain qwen-max is retired
#    in the 2026 lineup -- use qwen3.7-max, or qwen3-max for a cheaper flagship.)
SIFT_DEFAULT_MODEL=qwen3.7-max               # fallback for any unset role
SIFT_MODEL_ANALYSIS=qwen3.7-max              # Inv2 keystone analysis
SIFT_MODEL_INV3A=qwen3.7-max                 # final self-correction adjudication
SIFT_INV2_ENSEMBLE_FORCE_MODEL=qwen-plus     # the 4-member ensemble (volume)
SIFT_MODEL_REACT=qwen-plus                   # ~49 ReAct cross-check probes (volume)
SIFT_MODEL_INV1_PRIMARY=qwen-plus            # tool selection
SIFT_MODEL_REPORT=qwen-plus                  # report writing
SIFT_MODEL_SELF_CORRECTION=qwen-plus         # (legacy SC path; usually deferred to 13AA)

# 4a) Trust-layer finalization -- THE CONFIGURATION THE VERIFIED RUNS USED.
#     Step-13AA (inv3a) consolidates self-correction into ONE adjudication pass
#     and review-all re-judges every ambiguous finding to a final TP/FP verdict
#     (the shipped heavy run left ZERO inconclusive with these on). They are
#     code-gated OFF by default for byte-identical legacy behavior, so they must
#     be set here for a run to reproduce the advertised results. Measured
#     ablation (same case, flags off): 11 findings stayed inconclusive and only
#     1 cleared confirmation -- the layer resolves uncertainty, it never
#     manufactures confirmations (every promotion still passes the
#     deterministic eligibility gate). Kill-switch: set to 0.
SIFT_INV3A_FINALIZE=1                        # Step-13AA consolidated adjudication
SIFT_INV3A_REVIEW_ALL=1                      # 13AA re-judges ALL ambiguous findings
SIFT_ALLOW_YARA=1                            # include run_yara in tool selection (verified runs did)

# 4b) Output cap. DashScope 400s if max_tokens exceeds a model's output ceiling;
#     the client clamps to this (default 8192). Raise only after confirming the
#     model's cap in the console.
# SIFT_MAX_OUTPUT_TOKENS=8192

# 4c) Read timeout (seconds). qwen3.7-max with reasoning + a large evidence
#     context routinely takes >120s per call (a paired all-Max ensemble member
#     ran 131-222s); the old 120s default timed the whole ensemble out. 600 is a
#     safe ceiling for the flagship.
SIFT_HTTP_TIMEOUT=600

# 4d) Prompt caching is AUTOMATIC on Qwen/DashScope: shared prefixes (e.g. the
#     4-member ensemble's identical ~118k-token context) are cached server-side,
#     reported in usage as cached_tokens, and the provider seam credits them as
#     cache-read so cost reflects the reuse -- no cache_control needed. Set the
#     cached-token cost multiplier vs base input (default 0.10) to your console's
#     real cache-hit rate for an exact readout.
# SIFT_CACHE_READ_MULT=0.10

# 4e) OPT-IN ReAct prefix caching (SIFT_REACT_CACHE_PREFIX, default OFF). When set
#     to 1 the ReAct prompt is reordered so the static run-constant block
#     (instructions + tool catalog + OS context + coverage + escalation) is emitted
#     FIRST and reused across every ReAct turn -- a longer shared prefix that
#     DashScope can cache server-side, cutting input cost on the ~49 ReAct probes.
#     Left OFF by default ON PURPOSE: moving the finding from the front to after the
#     static block is a prompt reorder, and a reorder can shift model verdicts, so
#     enable it only after a live verdict A/B confirms no detection change. The
#     cached prefix carries segment boundaries only -- never case data.
# SIFT_REACT_CACHE_PREFIX=1

# 4f) OPT-IN human-in-the-loop approval checkpoint (SIFT_HITL_CHECKPOINT, default
#     OFF). When set to 1 AND running in a terminal, the pipeline PAUSES at the
#     critical decision point -- after the deterministic disposition, before the
#     report -- and shows the confirmed + needs-review findings so the analyst can
#     APPROVE them or OVERRIDE any finding's bucket. The override propagates into
#     the report. Default OFF + TTY-gated, so autonomous/headless runs are
#     unaffected. (Track-4: human-in-the-loop checkpoint at a critical decision point.)
# SIFT_HITL_CHECKPOINT=1

# 5) Cost readout: the pricing table carries APPROXIMATE DashScope rates
#    (qwen3.7-max ~2.5/7.5, qwen-plus ~0.4/1.2 USD per MTok). Pin your real
#    console rates here if you want the printed $ to match the invoice exactly.
# SIFT_PRICE_INPUT_PER_MTOK=2.5
# SIFT_PRICE_OUTPUT_PER_MTOK=7.5
