# ── Qwen Cloud (Alibaba Cloud / DashScope) provider config ────────────────
# Global AI Hackathon with Qwen Cloud -- Track 4 (Autopilot Agent).
#
# Copy to .env (or `source` it) and fill in DASHSCOPE_API_KEY. Flipping the
# whole 16-step pipeline onto Qwen needs NO code change -- model selection is
# already env-driven (src/sift_sentinel/model_roles.py). The provider seam is
# src/sift_sentinel/llm_provider.py.

# 1) Select the Qwen provider (anything else -> Anthropic, the default).
SIFT_LLM_PROVIDER=qwen

# 2) Your Qwen Cloud key (request the $40 hackathon voucher; key from the
#    DashScope console). QWEN_API_KEY is also accepted.
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# 3) Endpoint. Default is the INTERNATIONAL (Singapore) OpenAI-compatible URL.
#    For mainland China use:
#    https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions

# 4) Models (verify exact current IDs in your DashScope model list).
#    Strategy: flagship qwen-max where reasoning matters; qwen-plus on the
#    high-call-volume stages so the $40 credit lasts.
SIFT_DEFAULT_MODEL=qwen-max                  # fallback for any unset role
SIFT_MODEL_ANALYSIS=qwen-max                 # Inv2 keystone analysis
SIFT_MODEL_INV3A=qwen-max                    # final self-correction adjudication
SIFT_INV2_ENSEMBLE_FORCE_MODEL=qwen-plus     # the 4-member ensemble (volume)
SIFT_MODEL_REACT=qwen-plus                   # ~49 ReAct cross-check probes (volume)
SIFT_MODEL_INV1_PRIMARY=qwen-plus            # tool selection
SIFT_MODEL_REPORT=qwen-plus                  # report writing
SIFT_MODEL_SELF_CORRECTION=qwen-plus         # (legacy SC path; usually deferred to 13AA)

# 5) Cost readout: the pricing table carries APPROXIMATE DashScope rates. Pin
#    your real rates from the console here (USD per million tokens) if you want
#    the printed $ to match the invoice exactly.
# SIFT_PRICE_INPUT_PER_MTOK=1.6
# SIFT_PRICE_OUTPUT_PER_MTOK=6.4
